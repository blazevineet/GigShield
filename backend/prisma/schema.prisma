// GigShield — Database Schema (Phase 3 Intelligence Optimized)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────

enum PolicyStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  CANCELLED
}

enum ClaimStatus {
  PENDING
  AUTO_APPROVED
  SOFT_HOLD
  HARD_HOLD
  PAID
  REJECTED
  SETTLED         // Completed Phase 3 lifecycle
  MANUAL_REVIEW   // ML-flagged anomalies
}

enum TriggerType {
  RAIN
  HEAVY_RAINFALL
  EXTREME_HEAT
  FLOOD_ALERT
  SEVERE_AQI
  ORDER_COLLAPSE
  CURFEW_BANDH
}

enum PayoutStatus {
  QUEUED
  PROCESSING
  SUCCESS
  FAILED
}

enum UserRole {
  WORKER
  ADMIN
  INSURER
}

// ─── Models ───────────────────────────────────────────

model User {
  id            String         @id @default(uuid())
  phone         String         @unique
  aadhaarHash   String?        // last 4 digits, hashed
  name          String
  upiId         String?
  role          UserRole       @default(WORKER)
  isVerified    Boolean        @default(false)
  hasProfile    Boolean        @default(false) // Triggered after worker activation
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workerProfile WorkerProfile?
  otpRequests   OtpRequest[]
  refreshTokens RefreshToken[]

  @@index([phone])
  @@index([role]) // Optimized for Admin role-checks
  @@map("users")
}

model WorkerProfile {
  id             String         @id @default(uuid())
  userId         String         @unique
  platform       String         // Blinkit, Zepto, etc.
  zone           String         // Velachery, Tambaram, etc.
  city           String         @default("Chennai")
  avgDailyHours  Float          @default(8)
  tenureMonths   Int            @default(0)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  policies       Policy[]
  gpsPings       GpsPing[]

  @@index([zone])
  @@index([platform])
  @@map("worker_profiles")
}

model Policy {
  id             String         @id @default(uuid())
  workerId       String
  tier           String         // basic | standard | pro
  basePremium    Float
  finalPremium   Float          // AI-adjusted
  maxPayout      Float
  coverageHours  Int            @default(8)
  mlScore        Float?         // risk score from model
  mlMultiplier   Float?
  mlExplanation  String?        // Stores the string explanation from Python
  featureBreakdown Json?        // Stores the detailed weights (Flood index, etc.)
  status         PolicyStatus   @default(ACTIVE)
  issuedAt       DateTime       @default(now())
  expiresAt      DateTime
  renewedFromId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // CHANGED: Added Cascade delete so clearing test data doesn't break relations
  worker         WorkerProfile  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  claims         Claim[]

  @@index([workerId])
  @@index([status])
  @@map("policies")
}

model Claim {
  id             String        @id @default(uuid())
  policyId       String
  triggerType    TriggerType
  triggerValue   Float          // actual measured value
  threshold      Float          // threshold that was breached
  severity       Float?         // Severity score from ML (0.0 to 2.0)
  aiConfidence   Float?         // Confidence score (0.0 to 1.0)
  isAnomaly      Boolean        @default(false) 
  alerts         String[]       
  payoutAmount   Float
  status         ClaimStatus    @default(PENDING)
  autoTriggered  Boolean        @default(true)
  notes          String?        
  adjusterNotes  String?        
  firedAt        DateTime       @default(now())
  resolvedAt     DateTime?
  settledAt      DateTime?      
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  policy         Policy         @relation(fields: [policyId], references: [id], onDelete: Cascade)
  payout         Payout?

  @@index([policyId])
  @@index([status])
  @@index([triggerType]) // Important for Admin analytics
  @@map("claims")
}

model Payout {
  id                String       @id @default(uuid())
  claimId           String       @unique
  amount            Float
  upiId             String
  razorpayPayoutId  String?
  status            PayoutStatus @default(QUEUED)
  failureReason     String?
  metadata          Json?        
  initiatedAt       DateTime     @default(now())
  completedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  claim             Claim        @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("payouts")
}

model GpsPing {
  id          String   @id @default(uuid())
  workerId    String
  lat         Float
  lon         Float
  accuracy    Float?   
  speed       Float?
  recordedAt  DateTime @default(now())

  worker      WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, recordedAt])
  @@map("gps_pings")
}

model TriggerEvent {
  id           String      @id @default(uuid())
  triggerType  TriggerType
  zone         String
  value        Float
  threshold    Float
  source       String      // Open-Meteo, IMD, etc.
  claimsRaised Int         @default(0)
  rawPayload   Json?       
  recordedAt   DateTime    @default(now())

  @@index([triggerType, recordedAt])
  @@index([zone])
  @@map("trigger_events")
}

model OtpRequest {
  id        String   @id @default(uuid())
  userId    String
  otp       String   
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_requests")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ZoneRiskProfile {
  id             String   @id @default(uuid())
  zone           String   @unique
  city           String
  floodRiskIndex Float
  claimFrequency Float
  lat            Float
  lon            Float
  updatedAt      DateTime @updatedAt

  @@map("zone_risk_profiles")
}