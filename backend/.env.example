# ─── App ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://gigshield:password@localhost:5432/gigshield_db"

# ─── Redis ────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_ACCOUNT_NUMBER=your_account_number

# ─── ML Service ───────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ─── Open-Meteo (no key needed) ───────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ─── SMS (Twilio / MSG91) ─────────────────────────────
SMS_PROVIDER=msg91
MSG91_API_KEY=your_msg91_key
MSG91_SENDER_ID=GIGSHL
MSG91_TEMPLATE_ID=your_template_id

# ─── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://gigshield.in

# ─── Rate limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
